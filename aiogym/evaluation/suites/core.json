        "randomize_setpoints": false,
        "randomize_plant": false,
        "plant_drift": false,
        "noise": false
      }
    },
    {
      "scenarios": ["cascade"],
      "objective": "economic",
      "task": "continuous-benchmark"
    },
    {
      "scenarios": ["cstr", "hvac"],
      "objective": "economic",
      "environment": {
        "dynamic": true,
        "randomize": true,
        "randomize_setpoints": false,
        "randomize_plant": true,
        "plant_drift": true,
        "noise": false
      }
    }
  ]
