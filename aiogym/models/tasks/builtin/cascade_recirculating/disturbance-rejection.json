{
  "schema_version": "aiogym.task_profile.v1",
  "name": "disturbance-rejection",
  "scenario": "cascade-recirculating",
  "status": "benchmark-designed",
  "description": "Deterministic rejection of P101 capacity, H1 efficiency, and laboratory ambient changes around the nominal closed-loop equilibrium.",
  "default_objective": "robustness",
  "supported_objectives": ["tracking", "kpi", "robustness", "safety"],
  "environment": {
    "control_dt": 0.5,
    "episode_steps": 1400,
    "action_mode": "actuator",
    "auto_events": false,
    "randomize": false,
    "randomize_setpoints": false,
    "randomize_plant": false,
    "plant_drift": false,
    "integral_obs": false,
    "terminate_on_runaway": false,
    "noise": false,
    "noise_pct": 0.01
  },
  "initialization": {
    "state": [0.4, 30.0, 0.4, 28.932991890738368, 0.4, 27.57566937897707],
    "basis": "model-consistent nominal equilibrium"
  },
  "setpoints": {
    "initial": [0.4, 0.4, 0.4, 30.0, 28.932991890738368, 27.57566937897707],
    "schedule": []
  },
  "disturbances": [
    {"at_step": 200, "name": "pump_flow_factor", "value": 0.75, "description": "25% P101 capacity loss"},
    {"at_step": 400, "name": "pump_flow_factor", "value": 1.0, "description": "P101 capacity restored"},
    {"at_step": 600, "name": "heater_efficiency", "value": 0.7, "description": "H1 heat-transfer efficiency loss"},
    {"at_step": 800, "name": "heater_efficiency", "value": 1.0, "description": "H1 efficiency restored"},
    {"at_step": 1000, "name": "t_amb", "value": 15.0, "description": "cool laboratory ambient step"},
    {"at_step": 1200, "name": "t_amb", "value": 20.0, "description": "ambient restored"}
  ],
  "constraints": [
    {"name": "tank_levels", "bounds": [0.0, 0.5], "unit": "m"},
    {"name": "tank_temperatures", "bounds": [0.0, 92.0], "unit": "degC"}
  ],
  "acceptance": {
    "required_checks": [
      "deterministic_disturbance_schedule",
      "disturbance_values_exposed_to_controller",
      "finite_recovery_rollout",
      "protection_event_accounting"
    ]
  },
  "references": [
    {
      "id": "cascade-retrofit-layout-2024",
      "locator": "PDF identifies P101 VFD, 2 kW H1, and unstable Lab A1 voltage; event magnitudes are AIO-Gym assumptions"
    }
  ]
}
